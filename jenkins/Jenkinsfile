pipeline {

    agent any

    options {
        timeout(time: 15, unit: 'MINUTES')
        disableConcurrentBuilds()
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    environment {

        IMAGE_TAG = "${BUILD_NUMBER}"

        PREVIOUS_TAG = "stable"

        AWS_REGION = "eu-central-1"

        APP_NAME = "account-service"
    }

    stages {

        stage('Checkout') {

            steps {

                git branch: 'main',
                url: 'https://github.com/pmaity1995/fintrack-release-recovery.git'

                milestone ordinal: 1
            }
        }

        stage('Build Docker Image') {

            steps {

                sh '''
                echo "Building Docker image..."

                docker build \
                -t ${APP_NAME}:${IMAGE_TAG} \
                -f docker/account-service.Dockerfile .
                '''
            }
        }

        stage('Secure Docker Login') {

            steps {

                withCredentials([
                    string(credentialsId: 'docker-token', variable: 'TOKEN')
                ]) {

                    sh '''
                    echo "Logging into Docker securely..."

                    echo $TOKEN | docker login \
                    -u barney1995 \
                    --admin-stdin
                    '''
                }
            }
        }

        stage('Deploy Canary') {

            steps {

                retry(2) {

                    sh '''
                    echo "Deploying Kubernetes manifests..."

                    kubectl apply -f k8s/account-deployment.yaml

                    kubectl apply -f istio/virtualservice.yaml
                    '''
                }
            }
        }

        stage('Health Check') {

            steps {

                script {

                    echo "Running health checks..."

                    def STATUS = sh(
                        script: """
                        curl -s -o /dev/null \
                        -w '%{http_code}' \
                        http://localhost:8080/health
                        """,
                        returnStdout: true
                    ).trim()

                    echo "HTTP STATUS: ${STATUS}"

                    if (STATUS.startsWith("5")) {

                        echo "5XX detected. Triggering rollback..."

                        sh "./scripts/rollback.sh ${PREVIOUS_TAG}"

                        error("Deployment failed due to 5XX errors")
                    }
                }
            }
        }
    }

    post {

        success {

            echo 'Deployment completed successfully'
        }

        failure {

            echo 'Deployment failed'

            mail to: 'devops-team@fintrack.com',
            subject: 'Production Deployment Failed',
            body: '''
Deployment failed during health validation.

Automatic rollback was triggered successfully.

Please review:
- Jenkins logs
- Kubernetes events
- Istio routing
- Pod health
'''
        }

        always {

            cleanWs()

            echo 'Workspace cleaned successfully'
        }
    }
}